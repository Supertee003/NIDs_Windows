      "layer": "L7_PIPE",
      "fast_pattern": "OSI_SEMI",
      "match_pattern": "; id",
      "regex_pattern": "INFO:OSI_SEMI|;\\\\s*id|;\\\\s*whoami",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0065",
