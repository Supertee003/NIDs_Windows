{
  "nids_rules": [
    {
      "_comment": "PACKET ANOMALY DETECTION"
    },
    {
      "rule_id": "R0001",
      "name": "TCP XMAS Scan (Standard)",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "FPU",
      "match_pattern": "FLAGS:FPU",
      "regex_pattern": "FLAGS:(FPU|0x29|XMAS_SCAN_STD)",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "rule_id": "R0002",
      "name": "TCP FIN Scan",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "FLAGS:F",
      "match_pattern": "0x01",
      "regex_pattern": "FLAGS:F|0x01|FIN_SCAN",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "rule_id": "R0003",
      "name": "TCP NULL Scan",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "NONE",
      "match_pattern": "FLAGS:NONE",
      "regex_pattern": "FLAGS:NONE|0x00|NULL_SCAN",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "rule_id": "R0006",
      "name": "TCP SYN Stealth Scan",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "SYN_STEALTH",
      "match_pattern": "FLAGS:S",
      "regex_pattern": "INFO:SYN_STEALTH|FLAGS:S|0x02",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "rule_id": "R0007",
      "name": "TCP ACK Scan (Firewall Probe)",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "ACK_SCAN",
      "match_pattern": "FLAGS:A",
      "regex_pattern": "INFO:ACK_SCAN|FLAGS:A|0x10",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0008",
      "name": "UDP Port Scan",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "UDP_SCAN",
      "match_pattern": "PROTO:UDP",
      "regex_pattern": "INFO:UDP_SCAN|PROTO:UDP",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0009",
      "name": "TCP Window Scan",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "WINDOW_SCAN",
      "match_pattern": "WIN:",
      "regex_pattern": "INFO:WINDOW_SCAN|WIN:[1-9][0-9]*",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0010",
      "name": "ICMP Timestamp Request",
      "category": "Reconnaissance",
      "layer": "L3",
      "fast_pattern": "ICMP_TS",
      "match_pattern": "TYPE:13",
      "regex_pattern": "INFO:ICMP_TS|TYPE:13",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0011",
      "name": "ICMP Address Mask Scan",
      "category": "Reconnaissance",
      "layer": "L3",
      "fast_pattern": "ICMP_MASK",
      "match_pattern": "TYPE:17",
      "regex_pattern": "INFO:ICMP_MASK|TYPE:17",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0020",
      "name": "NetBIOS Name Discovery",
      "category": "Reconnaissance",
      "layer": "L4",
      "fast_pattern": "NETBIOS_SCAN",
      "match_pattern": "PORT:137",
      "regex_pattern": "INFO:NETBIOS_SCAN|PORT:137",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0031",
      "name": "ICMP Flood",
      "category": "DoS",
      "layer": "L3",
      "fast_pattern": "ICMP_FLOOD",
      "match_pattern": "TYPE:8",
      "regex_pattern": "INFO:ICMP_FLOOD|TYPE:8|COUNT:>100",
      "severity": "High",
      "action": "Drop"
    },
    {
      "rule_id": "R0032",
      "name": "IGMP Membership Query Flood",
      "category": "DoS",
      "layer": "L3",
      "fast_pattern": "IGMP_FLOOD",
      "match_pattern": "PROTO:IGMP",
      "regex_pattern": "INFO:IGMP_FLOOD|PROTO:IGMP",
      "severity": "Medium",
      "action": "Drop"
    },
    {
      "rule_id": "R0040",
      "name": "TCP Connection Exhaustion",
      "category": "DoS",
      "layer": "L4",
      "fast_pattern": "CONN_EXHAUST",
      "match_pattern": "ESTABLISHED",
      "regex_pattern": "INFO:CONN_EXHAUST|ESTABLISHED\\s*>\\s*1000",
      "severity": "High",
      "action": "Alert"
    },
    {
      "rule_id": "R0041",
      "name": "Ping of Death",
      "category": "DoS",
      "layer": "L3",
      "fast_pattern": "POD",
      "match_pattern": "SIZE:>65535",
      "regex_pattern": "INFO:POD|SIZE:>(6553[5-9]|655[4-9][0-9]|65[6-9][0-9]{2}|6[6-9][0-9]{3}|[7-9][0-9]{4})",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0042",
      "name": "Smurf Attack",
      "category": "DoS",
      "layer": "L3",
      "fast_pattern": "SMURF",
      "match_pattern": "ICMP_ECHO_BROADCAST",
      "regex_pattern": "INFO:SMURF|ICMP_ECHO_BROADCAST",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0043",
      "name": "Fraggle Attack",
      "category": "DoS",
      "layer": "L4",
      "fast_pattern": "FRAGGLE",
      "match_pattern": "UDP_ECHO_7",
      "regex_pattern": "INFO:FRAGGLE|UDP_ECHO_7",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0052",
      "name": "TCP Resubmission Flood",
      "category": "DoS",
      "layer": "L4",
      "fast_pattern": "TCP_RESUB",
      "match_pattern": "RETRANSMIT_COUNT",
      "regex_pattern": "INFO:TCP_RESUB|RETRANSMIT_COUNT\\s*>\\s*50",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "_comment": "PROTOCOL ANOMALY"
    },
    {
      "rule_id": "R0004",
      "name": "ARP Network Sweep",
      "category": "Reconnaissance",
      "layer": "L2_PIPE",
      "fast_pattern": "ARP_SWEEP",
      "match_pattern": "DST_MAC:ff:ff:ff:ff:ff:ff",
      "regex_pattern": "OP:1|DST_MAC:ff:ff:ff:ff:ff:ff|INFO:ARP_SWEEP",
      "severity": "Low",
      "action": "Alert"
    },
    {
      "rule_id": "R0021",
      "name": "VLAN Tag Probing",
      "category": "Reconnaissance",
      "layer": "L2_PIPE",
      "fast_pattern": "VLAN_PROBE",
      "match_pattern": "DOT1Q",
      "regex_pattern": "INFO:VLAN_PROBE|DOT1Q",
      "severity": "Medium",
      "action": "Alert"
    },
    {
      "rule_id": "R0044",
      "name": "Land Attack (Same Src/Dst)",
      "category": "DoS",
      "layer": "L3",
      "fast_pattern": "LAND_ATTACK",
      "match_pattern": "SRC_IP==DST_IP",
      "regex_pattern": "INFO:LAND_ATTACK|SRC_IP==DST_IP",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0045",
      "name": "BGP Session Reset",
      "category": "DoS",
      "layer": "L4",
      "fast_pattern": "BGP_RESET",
      "match_pattern": "PORT:179",
      "regex_pattern": "INFO:BGP_RESET|PORT:179|FLAGS:R",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0116",
      "name": "Anomaly (Unknown IP Proto)",
      "category": "Anomaly",
      "layer": "L3",
      "fast_pattern": "ZERO_DAY",
      "match_pattern": "PROTO_NUM:253",
      "regex_pattern": "INFO:ZERO_DAY|PROTO_NUM:253",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "_comment": "APPLICATION HEADER ANALYSIS"
    },
    {
      "rule_id": "R0012",
