      "category": "Reconnaissance",
      "layer": "L7",
      "fast_pattern": "VER_SCAN",
      "match_pattern": "nmap",
      "regex_pattern": "INFO:VER_SCAN|nmap|zgrab|masscan",
      "severity": "Medium",
      "action": "Alert"
    },
    {
