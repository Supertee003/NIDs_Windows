      "action": "Alert"
    },
    {
      "_comment": "CONTENT-BASED DETECTION"
    },
    {
      "rule_id": "R9056",
      "name": "SQL Injection (Auth Bypass)",
      "category": "Injection",
      "layer": "L7",
      "fast_pattern": "SQLI_BYPASS",
      "match_pattern": "' OR 1=1",
      "regex_pattern": "'\\s*OR\\s*1=1|'\\s*OR\\s*'1'='1|INFO:SQLI_BYPASS",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0057",
      "name": "SQL Injection (Time-based)",
      "category": "Injection",
      "layer": "L7",
      "fast_pattern": "SQLI_TIME",
      "match_pattern": "SLEEP(",
      "regex_pattern": "SLEEP[(]|WAITFOR\\s+DELAY|INFO:SQLI_TIME",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R0058",
      "name": "OS Command Injection (Pipe)",
      "category": "System Compromise",
      "layer": "L7_PIPE",
      "fast_pattern": "OS_CMD_PIPE",
      "match_pattern": "; cat",
      "regex_pattern": ";\\\\s*cat|\\\\|\\\\s*ls|INFO:OS_CMD_PIPE",
      "severity": "Critical",
      "action": "Drop"
    },
    {
      "rule_id": "R9059",
